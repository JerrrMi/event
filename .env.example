# Trading symbol and K-line interval
SYMBOL=BTCUSDT
INTERVAL=1m

# Prediction horizon (minutes)
PREDICTION_MINUTES=10

# ARIMA model settings
ARIMA_ORDER=1,0,1
TRAIN_WINDOW=1440
REFIT_INTERVAL_MINUTES=5

# Signal filtering
CONFIDENCE_THRESHOLD=0.70
SIGNAL_COOLDOWN_MINUTES=10
MAX_SPREAD_BPS=50

# Binance data source (spot or futures; API keys optional for public market data)
BINANCE_MARKET=spot
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Live data collection (REST polling)
LIVE_POLL_INTERVAL_SECONDS=10
LIVE_KLINE_LIMIT=2
LIVE_MAX_RETRIES=5
LIVE_RETRY_BACKOFF=1.0
LIVE_MAX_CONSECUTIVE_ERRORS=10
LIVE_ERROR_RETRY_DELAY_SECONDS=5

# Runtime
DRY_RUN=true
LOG_LEVEL=INFO

# Paths (relative to project root)
DATA_DIR=data
LOGS_DIR=logs
