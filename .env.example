# Trading symbol and K-line interval
SYMBOL=BTCUSDT
INTERVAL=1m

# Prediction horizon (minutes)
PREDICTION_MINUTES=10

# ARIMA model settings
ARIMA_ORDER=1,0,1
ARIMA_SERIES_TYPE=log_return
USE_AUTO_ARIMA=false
AUTO_ARIMA_MAX_P=5
AUTO_ARIMA_MAX_Q=5
AUTO_ARIMA_MAX_D=2
DIRECTION_THRESHOLD=0.0
TRAIN_WINDOW=1440
REFIT_INTERVAL_MINUTES=5

# GARCH model settings (log-return volatility; set USE_GARCH=false for ARIMA-only)
USE_GARCH=true
GARCH_ORDER=1,1
GARCH_MEAN=constant
GARCH_DIST=normal
GARCH_MIN_TRAIN_POINTS=100
GARCH_VOL_SCALE=1.0
# hold = output HOLD when GARCH fails; fallback_to_arima = use ARIMA direction only
GARCH_FAILURE_MODE=hold

# ARIMA-GARCH aggregation (volatility_adjusted_arima: filter by GARCH risk + adjusted SNR)
AGGREGATION_MODE=volatility_adjusted_arima
AGGREGATION_MIN_SNR=0.8
# hold = no signal on EXTREME volatility; allow_with_penalty = allow with lower confidence
GARCH_EXTREME_VOL_ACTION=hold
GARCH_VOL_WEIGHT=0.35

# Signal filtering
CONFIDENCE_THRESHOLD=0.70
SIGNAL_COOLDOWN_MINUTES=10
MAX_SPREAD_BPS=50

# Binance data source (spot or futures; API keys optional for public market data)
BINANCE_MARKET=spot
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# Telegram Bot (required when DRY_RUN=false)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Live data collection (REST polling)
LIVE_POLL_INTERVAL_SECONDS=10
LIVE_KLINE_LIMIT=2
LIVE_MAX_RETRIES=5
LIVE_RETRY_BACKOFF=1.0
LIVE_MAX_CONSECUTIVE_ERRORS=10
LIVE_ERROR_RETRY_DELAY_SECONDS=5

# Runtime (DRY_RUN=true: log only, no real Telegram sends)
DRY_RUN=true
LOG_LEVEL=INFO

# Paths (relative to project root)
DATA_DIR=data
LOGS_DIR=logs
